# Telegram bot token (получить у @BotFather)
BOT_TOKEN=

# Telegram ID владельца (Владимира). Только этот ID получит доступ.
ADMIN_TELEGRAM_ID=

# Путь к SQLite-журналу (относительно корня проекта)
JOURNAL_DB_PATH=data/journal.sqlite3

# Уровень логирования: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# Внутренний URL Travel Content Factory на этом же VPS.
# Пример: http://127.0.0.1:8010/internal/generate
CONTENT_FACTORY_INTERNAL_URL=

# Внутренний токен Travel Content Factory.
# НЕ публиковать, НЕ логировать, НЕ коммитить настоящее значение.
CONTENT_FACTORY_INTERNAL_TOKEN=

# Таймаут сетевого вызова Content Factory, секунды (по умолчанию 20).
CONTENT_FACTORY_TIMEOUT_SECONDS=20

# Путь к локальной SQLite-базе Travel Lead Radar на этом же VPS.
# TA Control Center читает leads.db напрямую (только чтение, без HTTP-сервиса).
# Файл action_recommender.py подгружается по пути, выведенному из этого:
#   <LEAD_RADAR_DB_PATH>/../../app/ai/action_recommender.py
LEAD_RADAR_DB_PATH=/opt/travel_lead_radar/data/leads.db
